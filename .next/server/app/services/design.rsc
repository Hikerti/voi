a:["$","$1","c",{"children":[[["$","$Le",null,{"backHref":"/services","backLabel":"back to complex","backLabelClass":"backtoysl"}],["$","$Lf",null,{}],["$","$L10",null,{"desktopClass":"services-parent1-1","leftIconClass":"left-side-child-conent1-1","spacerClass":"services-left1-1","rightClass":"services-right-2-1-1","contentClass":"content-parent-ser1-1-1112","mobileClass":"mobile-services","mobileHeroClass":"services-hero","mobileContentClass":"services-content-st","icon":"/images/winOpered.png","nextHref":"/services/digital","nextLabel":"Next Digital","desktopContent":[["$","h1",null,{"className":"heading-38","children":"Дизайн"}],["$","h1",null,{"className":"heading-37","children":"Подход к дизайну"}],["$","p",null,{"className":"paragraph-312","children":["$","strong",null,{"children":"Мы увлечены визуальными решениями, которые работают на бизнес‑результат. Для нас дизайн — это не просто картинка, а инструмент коммуникации и инновации в простой, понятной форме. Мы погружаемся в атмосферу вашего бренда, изучаем эмоции и ассоциации, чтобы создавать концепции, которые откликаются вашей аудитории."}]}],["$","h1",null,{"className":"heading-39","children":"Создание логотипа"}],["$","p",null,{"className":"paragraph-313","children":["$","strong",null,{"children":"Мы разрабатываем логотипы, которые легко запоминаются и формируют устойчивый образ компании в сознании клиентов. Знак, шрифт, цвет и форма работают вместе, чтобы передать характер и ценности вашего сервиса. В итоге вы получаете узнаваемый визуальный символ и сильную «визитную карточку» бренда, которая выделяет вас среди конкурентов."}]}],["$","h1",null,{"className":"heading-40","children":"Руководство по бренду"}],["$","p",null,{"className":"paragraph-314","children":["$","strong",null,{"children":"Мы создаём продуманное бренд‑руководство, которое фиксирует ключевые правила использования фирменного стиля. В него входят логотип и его варианты, цветовая палитра, шрифты, графические элементы и принципы их применения. Чёткие стандарты помогают сохранять последовательность во всех каналах, усиливая узнаваемость и доверие к бренду."}]}],["$","h1",null,{"className":"heading-54","children":"Полиграфический дизайн"}],["$","p",null,{"className":"paragraph-324","children":"Мы не просто делаем цифровые. Редко печать существует в вакууме. Скорее, это часть многоканальной или многоканальной кампании. Мы фокусируемся на мельчайших деталях, чтобы обеспечить блестящую, четкую и качественную композицию во всем нашем дизайне."}]],"mobileContent":[["$","h1",null,{"className":"heading-43","children":"Дизайн"}],["$","h1",null,{"className":"heading-44","children":"Подход к дизайну"}],["$","p",null,{"className":"paragraph-316","children":"Мы увлечены дизайном. Мы верим, что искусство — это инновация в самой простой форме. Мы позволяем себе погрузиться в «настроение» и позволяем нашим мыслям влиять на наше творение."}],["$","h1",null,{"className":"heading-45","children":"Создание логотипа"}],["$","p",null,{"className":"paragraph-317","children":"Мы создаем что-то запоминающееся. Ваш логотип является знаком, который вы оставляете в сознании потребителей. Мы помогаем отразить суть вашего сервиса и создать мгновенно узнаваемую визитную карточку."}],["$","h1",null,{"className":"heading-46","children":"Руководство по бренду"}],["$","p",null,{"className":"paragraph-318","children":"Мы создаем ваш фирменный набор инструментов. Мы считаем, что последовательность — это ключ к развитию вашего бренда, поэтому мы устанавливаем правила, чтобы обеспечить эффективную коммуникацию вашего бренда."}],["$","h1",null,{"className":"heading-55","children":"Полиграфический дизайн"}],["$","p",null,{"className":"paragraph-325","children":"Мы не просто делаем цифровые. Редко печать существует в вакууме. Скорее, это часть многоканальной или многоканальной кампании. Мы фокусируемся на мельчайших деталях, чтобы обеспечить блестящую, четкую и качественную композицию во всем нашем дизайне."}]]}]],["$L11"],"$L12"]}]
